# MongoDB
MONGODB_URI=mongodb://localhost:27017/mykonos-db
# Production example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/mykonos-db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL. Use comma-separated URLs if needed.
FRONTEND_URL=http://localhost:5173

# Development-only bootstrap route: POST /api/auth/init-admin
ENABLE_INIT_ADMIN=false
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change_this_password
INIT_ADMIN_NAME=Administrador Principal
